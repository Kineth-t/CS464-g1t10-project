{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js"],
      "port": 5173,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "Backend (Go)",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/api"],
      "port": 8080,
      "cwd": "backend",
      "env": {
        "DATABASE_URL": "postgres://root:mysecretpassword@localhost:5432/phonestore",
        "JWT_SECRET": "phonestore-jwt-secret-cs464",
        "ADMIN_PASSWORD": "Admin1234!"
      }
    }
  ]
}
