# Root .env — used by Docker Compose for local development.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

# Full PostgreSQL connection string used by the Go API.
# In docker-compose this points to the 'db' service container.
DATABASE_URL=postgres://root:mysecretpassword@localhost:5432/phonestore

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────

# Secret key used to sign and verify JWTs. Use a long random string in production.
JWT_SECRET=phonestore-jwt-secret-cs464

# Password for the admin account that gets seeded on first startup.
ADMIN_PASSWORD=Admin1234!

# ─────────────────────────────────────────────
# PAYMENTS
# ─────────────────────────────────────────────

# Stripe secret key. Use a sk_test_... key for development and sk_live_... in production.
# Get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# Origin the backend will accept cross-origin requests from.
# In production set this to the frontend's public URL (e.g. https://ringr.up.railway.app).
# Defaults to * (all origins) when not set — fine for local dev.
ALLOWED_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
# DOCKER COMPOSE
# ─────────────────────────────────────────────

# Prefix for Docker Compose container / network / volume names.
COMPOSE_PROJECT_NAME=ringr_mobile
