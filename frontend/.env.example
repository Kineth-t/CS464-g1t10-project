# Frontend .env — Vite reads variables prefixed with VITE_ at build time.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: In local development you usually don't need any of these — Vite's built-in
# dev proxy (vite.config.js) already forwards /api requests to http://127.0.0.1:8080.

# ─────────────────────────────────────────────
# API (production / Railway)
# ─────────────────────────────────────────────

# Base URL the browser uses for all API calls.
# Leave unset for local dev (falls back to /api via Vite proxy).
# Set to the backend's public URL only if you want the browser to call the
# backend directly instead of going through the nginx proxy.
# Example: VITE_API_URL=https://backend-production-xxxx.up.railway.app
VITE_API_URL=

# ─────────────────────────────────────────────
# NGINX (Railway / Docker only — not used by Vite)
# ─────────────────────────────────────────────

# Hostname and port nginx proxies /api/ requests to inside the container.
# Set this as a Railway environment variable on the frontend service.
# In Railway private networking this is: backend.railway.internal:8080
# Not needed for local dev — Vite handles the proxy instead.
BACKEND_URL=backend.railway.internal:8080
