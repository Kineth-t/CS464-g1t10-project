# Backend .env — used directly by the Go API and by docker-compose to provision Postgres.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

# Credentials used by docker-compose to create the Postgres container.
POSTGRES_USER=root
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=phonestore

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────

# Secret key used to sign and verify JWTs. Use a long random string in production.
JWT_SECRET=phonestore-jwt-secret-cs464

# Password for the admin account that gets seeded on first startup.
ADMIN_PASSWORD=Admin1234!

# ─────────────────────────────────────────────
# PAYMENTS
# ─────────────────────────────────────────────

# Stripe secret key. Use a sk_test_... key for development and sk_live_... in production.
# Get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# ─────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────

# Redis connection URL. In docker-compose this points to the 'redis' service container.
# If unset, Redis is disabled and all caching / rate-limiting is skipped gracefully.
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# Origin the backend will accept cross-origin requests from.
# In production set this to the frontend's public URL (e.g. https://ringr.up.railway.app).
# Defaults to * (all origins) when not set — fine for local dev.
ALLOWED_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
# DOCKER COMPOSE
# ─────────────────────────────────────────────

# Prefix for Docker Compose container / network / volume names.
COMPOSE_PROJECT_NAME=ringr_mobile
