{
  "info": {
    "name": "Ringr Mobile API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "customerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "phoneId", "value": "" },
    { "key": "cartItemId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user id', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.id).to.be.a('number');",
                  "});",
                  "pm.test('Role is customer', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.role).to.eql('customer');",
                  "});",
                  "pm.test('Has address', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.address).to.be.an('object');",
                  "  pm.expect(res.address.city).to.eql('Singapore');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer1\",\n  \"password\": \"secret123\",\n  \"phone_number\": \"+6591234567\",\n  \"address\": {\n    \"street\": \"123 Orchard Road\",\n    \"city\": \"Singapore\",\n    \"state\": \"\",\n    \"country\": \"Singapore\",\n    \"zip_code\": \"238858\"\n  }\n}"
            }
          }
        },
        {
          "name": "Register - duplicate username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer1\",\n  \"password\": \"secret123\",\n  \"phone_number\": \"+6591234567\",\n  \"address\": {\n    \"street\": \"123 Orchard Road\",\n    \"city\": \"Singapore\",\n    \"state\": \"\",\n    \"country\": \"Singapore\",\n    \"zip_code\": \"238858\"\n  }\n}"
            }
