          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/phones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 15\",\n  \"price\": 1299.00,\n  \"stock\": 50,\n  \"description\": \"No token\",\n  \"image_url\": \"https://example.com/images/iphone15.jpg\"\n}"
            }
