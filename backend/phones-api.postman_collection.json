          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"\",\n  \"password\": \"secret123\",\n  \"phone_number\": \"+6591234567\",\n  \"address\": {\n    \"street\": \"123 Orchard Road\",\n    \"city\": \"Singapore\",\n    \"state\": \"\",\n    \"country\": \"Singapore\",\n    \"zip_code\": \"238858\"\n  }\n}"
            }
          }
        },
        {
          "name": "Login customer",
          "event": [
            {
              "listen": "test",
              "script": {
