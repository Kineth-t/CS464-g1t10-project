    {
      "name": "Phones",
      "item": [
        {
          "name": "Create phone (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Phone saved and ID stored', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.id).to.be.a('number');",
                  "  pm.collectionVariables.set('phoneId', res.id);",
                  "  console.log('Phone ID saved:', res.id);",
                  "});",
                  "pm.test('Has correct fields', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.brand).to.eql('Apple');",
                  "  pm.expect(res.model).to.eql('iPhone 15');",
                  "  pm.expect(res.price).to.eql(1299);",
                  "  pm.expect(res.stock).to.eql(50);",
                  "});",
                  "pm.test('Has image_url', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.image_url).to.be.a('string');",
                  "  pm.expect(res.image_url).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/phones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 15\",\n  \"price\": 1299.00,\n  \"stock\": 50,\n  \"description\": \"Latest iPhone model\",\n  \"image_url\": \"https://example.com/images/iphone15.jpg\"\n}"
            }
          }
        },
