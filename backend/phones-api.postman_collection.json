                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.token).to.be.a('string');",
                  "  pm.collectionVariables.set('customerToken', res.token);",
                  "  console.log('Customer token saved');",
                  "});"
