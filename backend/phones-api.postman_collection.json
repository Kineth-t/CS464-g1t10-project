              "mode": "raw",
              "raw": "{\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 15\",\n  \"price\": 999.00,\n  \"stock\": -5,\n  \"description\": \"Bad stock\",\n  \"image_url\": \"https://example.com/images/iphone15.jpg\"\n}"
            }
          }
