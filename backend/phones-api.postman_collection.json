          "name": "List phones",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an('array');",
